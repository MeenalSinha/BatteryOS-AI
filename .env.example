# BatteryOS AI — Environment Configuration
# Copy this file to .env and fill in values

# Application
ENVIRONMENT=development
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
DEBUG=true

# Database (PostgreSQL + TimescaleDB)
DATABASE_URL=postgresql+asyncpg://batteryos:batteryos_secret@localhost:5432/batteryos

# Cache
REDIS_URL=redis://localhost:6379

# Time-Series
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=batteryos-super-secret-auth-token
INFLUX_ORG=batteryos
INFLUX_BUCKET=telemetry

# MQTT Broker
MQTT_HOST=localhost
MQTT_PORT=1883

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ML Model Paths (auto-populated after training)
DEGRADATION_MODEL_PATH=/app/ml_models/degradation_model.pkl
THERMAL_MODEL_PATH=/app/ml_models/thermal_model.pkl
ANOMALY_MODEL_PATH=/app/ml_models/anomaly_model.pkl

# Fleet
MAX_FLEET_SIZE=1000
TELEMETRY_INTERVAL_MS=1000
